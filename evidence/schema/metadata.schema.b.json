{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PayloadGuard evidence metadata - variant B (flattened pseudo-requirements)",
  "description": "T4-B fork of metadata.schema.json: preserves the one-record-per-binding shape. Concrete runs bind to shadow requirement entries whose id is a dotted child of the parent (e.g. REQ-GIP-1-8-1.concrete-1); every shadow entry MUST carry an explicit parent_requirement field (machine-enforced via if/then), so lineage is not naming-convention-only. Gaps are signalled by field absence, never by placeholder strings.",
  "type": "object",
  "additionalProperties": false,
  "required": ["device", "requirements", "toolchain"],
  "properties": {
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "safety_classification", "classification_rationale"],
      "properties": {
        "name": {"type": "string"},
        "intended_use": {"type": "string"},
        "safety_classification": {"enum": ["A", "B", "C"]},
        "classification_rationale": {"type": "string"},
        "iso14971_risk_file": {"type": "string"}
      }
    },
    "qms": {"type": "object"},
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "implementation", "intended_method"],
        "properties": {
          "id": {"type": "string", "pattern": "^REQ-[A-Z0-9-]+(\\.concrete-[0-9]+)?$"},
          "text": {"type": "string"},
          "implementation": {"type": "string"},
          "intended_method": {"enum": ["PROVEN", "BOUNDED_CHECKED", "TESTED", "EXAMPLE_CHECKED", "DECLARED"]},
          "parent_requirement": {"type": "string", "pattern": "^REQ-[A-Z0-9-]+$"}
        },
        "if": {
          "required": ["id"],
          "properties": {"id": {"pattern": "\\."}}
        },
        "then": {"required": ["parent_requirement"]}
      }
    },
    "threat_model": {"type": "array"},
    "sbom": {"type": "object"},
    "toolchain": {
      "type": "object",
      "required": ["crosshair_bounds"],
      "properties": {
        "crosshair_bounds": {
          "type": "object",
          "required": ["per_condition_timeout_s", "max_iterations", "seed"],
          "properties": {
            "per_condition_timeout_s": {"type": "number"},
            "max_iterations": {"type": "integer"},
            "seed": {"type": "integer"}
          }
        }
      }
    }
  }
}
