{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PayloadGuard evidence metadata",
  "description": "Validates examples/*/metadata.yaml. Gaps are signalled by field absence, never by placeholder strings. Phase-B Dafny parser note: the load-bearing log line is verbatim 'Dafny program verifier finished with N verified, 0 errors'; a parser must assert the literal substring '0 errors', not trust a zero exit code (false-zero bug in some Dafny versions).",
  "type": "object",
  "additionalProperties": false,
  "required": ["device", "requirements", "toolchain"],
  "properties": {
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "safety_classification", "classification_rationale"],
      "properties": {
        "name": {"type": "string"},
        "intended_use": {"type": "string"},
        "safety_classification": {"enum": ["A", "B", "C"]},
        "classification_rationale": {"type": "string"},
        "iso14971_risk_file": {"type": "string"}
      }
    },
    "qms": {"type": "object"},
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "implementation", "intended_method"],
        "properties": {
          "id": {"type": "string", "pattern": "^REQ-[A-Z0-9-]+$"},
          "text": {"type": "string"},
          "implementation": {"type": "string"},
          "intended_method": {"enum": ["PROVEN", "BOUNDED_CHECKED", "TESTED", "DECLARED"]}
        }
      }
    },
    "threat_model": {"type": "array"},
    "sbom": {"type": "object"},
    "toolchain": {
      "type": "object",
      "required": ["crosshair_bounds"],
      "properties": {
        "crosshair_bounds": {
          "type": "object",
          "required": ["per_condition_timeout_s", "max_iterations", "seed"],
          "properties": {
            "per_condition_timeout_s": {"type": "number"},
            "max_iterations": {"type": "integer"},
            "seed": {"type": "integer"}
          }
        }
      }
    }
  }
}
