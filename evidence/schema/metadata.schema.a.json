{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PayloadGuard evidence metadata - variant A (evidence array per requirement)",
  "description": "T4-A fork of metadata.schema.json: each requirement may carry an 'evidence' array of binding records (method 'crosshair' or 'concrete_test'; concrete records must name their test_id in concrete_results.json). Gaps are signalled by field absence, never by placeholder strings. Realized strength/caveat never appear in metadata; they come only from captures at generation time.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "device",
    "requirements",
    "toolchain"
  ],
  "properties": {
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "safety_classification",
        "classification_rationale"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "intended_use": {
          "type": "string"
        },
        "safety_classification": {
          "enum": [
            "A",
            "B",
            "C"
          ]
        },
        "classification_rationale": {
          "type": "string"
        },
        "iso14971_risk_file": {
          "type": "string"
        }
      }
    },
    "qms": {
      "type": "object"
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "text",
          "implementation",
          "intended_method"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^REQ-[A-Z0-9-]+$"
          },
          "text": {
            "type": "string"
          },
          "implementation": {
            "type": "string"
          },
          "intended_method": {
            "enum": [
              "PROVEN",
              "BOUNDED_CHECKED",
              "TESTED",
              "EXAMPLE_CHECKED",
              "DECLARED"
            ]
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "method"
              ],
              "properties": {
                "method": {
                  "enum": [
                    "crosshair",
                    "concrete_test"
                  ]
                },
                "test_id": {
                  "type": "string"
                }
              },
              "if": {
                "properties": {
                  "method": {
                    "const": "concrete_test"
                  }
                }
              },
              "then": {
                "required": [
                  "test_id"
                ]
              }
            }
          },
          "kernel_scope": {
            "type": "string"
          },
          "system_scope": {
            "type": "string"
          }
        }
      }
    },
    "threat_model": {
      "type": "array"
    },
    "sbom": {
      "type": "object"
    },
    "toolchain": {
      "type": "object",
      "required": [
        "crosshair_bounds"
      ],
      "properties": {
        "crosshair_bounds": {
          "type": "object",
          "required": [
            "per_condition_timeout_s",
            "max_iterations",
            "seed"
          ],
          "properties": {
            "per_condition_timeout_s": {
              "type": "number"
            },
            "max_iterations": {
              "type": "integer"
            },
            "seed": {
              "type": "integer"
            }
          }
        }
      }
    }
  }
}
