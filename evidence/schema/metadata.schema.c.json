{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PayloadGuard evidence metadata - variant C (dual matrix)",
  "description": "T4-C fork of metadata.schema.json: the metadata shape is UNCHANGED from the base (one-record-per-binding preserved end-to-end). Evidence partitioning happens at generation time: symbolic evidence binds by implementation match (as in the base matrix); concrete evidence is self-describing and binds by the requirement_id carried in each concrete_results.json case. Two independent artifacts are rendered (traceability_matrix.symbolic.* / traceability_matrix.concrete.*) by one renderer parametrised by method filter. intended_method enum gains EXAMPLE_CHECKED. Gaps are signalled by field absence, never by placeholder strings. The optional `evidence` field (2026-07-06, Gate 4 option 3) declares a top-down binding for CROSS-CHECKING ONLY - C's actual binding stays evidence-store-carried and unchanged; a mismatch between this declaration and the evidence store's self-declared requirement_id is a Type 1 CONFLICT (evidence/conflict.py).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "device",
    "requirements",
    "toolchain"
  ],
  "properties": {
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "safety_classification",
        "classification_rationale"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "intended_use": {
          "type": "string"
        },
        "safety_classification": {
          "enum": [
            "A",
            "B",
            "C"
          ]
        },
        "classification_rationale": {
          "type": "string"
        },
        "iso14971_risk_file": {
          "type": "string"
        }
      }
    },
    "qms": {
      "type": "object"
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "text",
          "implementation",
          "intended_method"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^REQ-[A-Z0-9-]+$"
          },
          "text": {
            "type": "string"
          },
          "implementation": {
            "type": "string"
          },
          "intended_method": {
            "enum": [
              "PROVEN",
              "BOUNDED_CHECKED",
              "TESTED",
              "EXAMPLE_CHECKED",
              "DECLARED"
            ]
          },
          "kernel_scope": {
            "type": "string"
          },
          "system_scope": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "method"
              ],
              "properties": {
                "method": {
                  "enum": [
                    "crosshair",
                    "concrete_test"
                  ]
                },
                "test_id": {
                  "type": "string"
                }
              },
              "if": {
                "properties": {
                  "method": {
                    "const": "concrete_test"
                  }
                }
              },
              "then": {
                "required": [
                  "test_id"
                ]
              }
            }
          }
        }
      }
    },
    "threat_model": {
      "type": "array"
    },
    "sbom": {
      "type": "object"
    },
    "toolchain": {
      "type": "object",
      "required": [
        "crosshair_bounds"
      ],
      "properties": {
        "crosshair_bounds": {
          "type": "object",
          "required": [
            "per_condition_timeout_s",
            "max_iterations",
            "seed"
          ],
          "properties": {
            "per_condition_timeout_s": {
              "type": "number"
            },
            "max_iterations": {
              "type": "integer"
            },
            "seed": {
              "type": "integer"
            }
          }
        }
      }
    }
  }
}
